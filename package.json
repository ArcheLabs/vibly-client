{
  "name": "@vibly-ai/client",
  "version": "0.1.0",
  "description": "Vibly Agent Node CLI and Daemon",
  "type": "module",
  "bin": {
    "vibly": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "node scripts/check-handwritten-paths.mjs && tsc --noEmit",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@vibly-ai/concord-adapter-substrate-actions": "^0.1.0",
    "@vibly-ai/concord-adapter-substrate-indexer": "^0.1.0",
    "@polkadot/api": "^16.5.6",
    "@polkadot/keyring": "^14.0.3",
    "@polkadot/util-crypto": "^14.0.3",
    "@vibly-ai/coordinator-http-contract": "^0.1.0",
    "better-sqlite3": "^9.6.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "eventsource-parser": "^3.0.0",
    "execa": "^9.3.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.4.5",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "default": "./dist/main.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  }
}
