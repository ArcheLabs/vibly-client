{
  "name": "vibly-client",
  "version": "0.1.0",
  "description": "Vibly Agent Node CLI and Daemon",
  "type": "module",
  "bin": {
    "vibly": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@concord/adapter-substrate-actions": "workspace:*",
    "@concord/adapter-substrate-indexer": "workspace:*",
    "better-sqlite3": "^9.6.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "eventsource-parser": "^3.0.0",
    "execa": "^9.3.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.4.5",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
